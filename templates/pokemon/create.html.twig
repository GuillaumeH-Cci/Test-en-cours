{% extends 'base.html.twig' %}

{% block title %}Création d'une nouvelle fiche Pokémon{% endblock %}

{% block body %}

    <div>
        <h1>Créer une nouvelle fiche Pokémon</h1>
    </div>

    <form method="post">
        <div class="card p-3 mb-3 bg-light mb-3 w-50 mx-auto">
            <div class="form-group">
                <label for="exampleInputEmail1">Nom du Pokémon</label>
                <input type="text" class="form-control" id="exampleInputEmail1" aria-describedby="emailHelp" placeholder="Entrer le nom du Pokémon">
            </div>
            <div class="form-group mt-3 mb-3">
                <label for="exampleInputPassword1">Type</label>
                <input type="text" class="form-control" id="exampleInputPassword1" placeholder="Entrer le type du Pokémon">
            </div>
            <button type="submit" class="btn btn-primary">Envoyer</button>
        </div>
    </form>
{% endblock %}